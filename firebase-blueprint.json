{
  "entities": {
    "Day": {
      "title": "Day",
      "description": "Incremental test day document",
      "type": "object",
      "properties": {
        "today": {
          "type": "string",
          "description": "ISO date string formatted as YYYY-MM-DD"
        }
      },
      "required": ["today"]
    },
    "User": {
      "title": "User",
      "description": "Authenticated user profile document",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Google UID of the user"
        },
        "name": {
          "type": "string",
          "description": "Full name of the user"
        },
        "email": {
          "type": "string",
          "description": "Email address of the user"
        },
        "initials": {
          "type": "string",
          "description": "Two-letter initials of the user"
        },
        "role": {
          "type": "string",
          "description": "User role: 'admin' or 'user'",
          "enum": ["admin", "user"]
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the user account is active"
        }
      },
      "required": ["uid", "name", "email", "initials", "role", "isActive"]
    }
  },
  "firestore": {
    "/days/{dayId}": {
      "schema": "#/entities/Day",
      "description": "Incremental test collection of days"
    },
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "Collection of registered users"
    }
  }
}
